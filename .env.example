# ==============================
# Обязательные переменные
# ==============================

# Секретный ключ Flask (минимум 32 символа, генерируется: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=замените_на_случайную_строку_минимум_32_символа

# Логин и пароль администратора. Несколько через запятую: admin1:pass1,admin2:pass2
# Пароль: минимум 8 символов
ADMIN_DATA=admin:замените_пароль

# ==============================
# База данных
# ==============================

# SQLite (по умолчанию, файл создаётся автоматически в папке data/):
# DATABASE_URL=sqlite:///data/conference_service.db

# Логировать SQL-запросы в консоль (только для отладки, никогда не включать в продакшне)
# SQLALCHEMY_ECHO=false

# MariaDB/MySQL:
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/conference_db

# ==============================
# Тема оформления
# ==============================

# Имя папки темы из app/themes/ (или "default" для базовой темы)
ACTIVE_THEME=default

# ==============================
# Почта (опционально)
# ==============================

# Включить отправку писем (true/false)
MAIL_ENABLED=false

# Включить верификацию email при регистрации (требует MAIL_ENABLED=true)
EMAIL_VERIFICATION_ENABLED=false

# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=your@email.com
# MAIL_PASSWORD=your_app_password
# MAIL_DEFAULT_SENDER=your@email.com

# ==============================
# Безопасность
# ==============================

# Установить true если сервер работает за HTTPS (обязательно в продакшне с SSL)
SESSION_COOKIE_SECURE=false

# ==============================
# Публичный URL
# ==============================

# Базовый URL сервиса — используется в ссылках внутри писем (уведомления, подтверждения)
# В продакшне замените на реальный домен: https://yourconference.com
BASE_URL=http://localhost:5000

# ==============================
# Gunicorn (продакшн)
# ==============================

# Количество воркеров (рекомендуется: 2 * CPU + 1)
# GUNICORN_WORKERS=4
